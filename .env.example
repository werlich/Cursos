DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,live.signau.cc
SITE_URL=http://127.0.0.1:8000

# MySQL (produção). Em local, deixe vazio para usar SQLite.
DJANGO_DB_NAME=
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=3306

# LivePix — https://livepix.gg (Configurações → Aplicações)
LIVEPIX_CLIENT_ID=
LIVEPIX_CLIENT_SECRET=
LIVEPIX_API_URL=https://api.livepix.gg
LIVEPIX_OAUTH_URL=https://oauth.livepix.gg
LIVEPIX_SCOPE=payments:write payments:read webhooks account:read
LIVEPIX_DEMO=true

MIN_ALUNOS_TURMA=10
PRECO_PADRAO=29.90
